  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Test Cloudflare Google Imagen 4 Image Generation\n",
    "\n",
    "This notebook allows you to test generating images using Cloudflare's **Google Imagen 4** model.\n",
    "\n",
    "### Prerequisites\n",
    "Make sure you have a `.env` file in the root of the project with the following keys:\n",
    "```env\n",
    "CLOUDFLARE_API_TOKEN=your_token\n",
    "CLOUDFLARE_ACCOUNT_ID=your_account_id\n",
    "```\n",
    "\n",
    "Ensure your environment has the required packages (`httpx`, `python-dotenv`, `pillow`, `ipython`)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import httpx\n",
    "from dotenv import load_dotenv\n",
    "from PIL import Image\n",
    "import io\n",
    "from IPython.display import display\n",
    "\n",
    "# Load environment variables from .env file\n",
    "load_dotenv()\n",
    "\n",
    "CLOUDFLARE_API_TOKEN = os.getenv(\"CLOUDFLARE_API_TOKEN\")\n",
    "CLOUDFLARE_ACCOUNT_ID = os.getenv(\"CLOUDFLARE_ACCOUNT_ID\")\n",
    "\n",
    "if not CLOUDFLARE_API_TOKEN or not CLOUDFLARE_ACCOUNT_ID:\n",
    "    print(\"❌ Error: Please ensure CLOUDFLARE_API_TOKEN and CLOUDFLARE_ACCOUNT_ID are defined in your .env file!\")\n",
    "else:\n",
    "    print(\"✅ Cloudflare configuration loaded successfully!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_image_imagen4(prompt: str, use_master_suffix: bool = True) -> bytes:\n",
    "    \"\"\"\n",
    "    Call Cloudflare Workers AI using Google's Imagen 4 model.\n",
    "    Generates a 1:1 PNG image with white background.\n",
    "    \"\"\"\n",
    "    url = f\"https://api.cloudflare.com/client/v4/accounts/{CLOUDFLARE_ACCOUNT_ID}/ai/run\"\n",
    "    \n",
    "    headers = {\n",
    "        \"Authorization\": f\"Bearer {CLOUDFLARE_API_TOKEN}\",\n",
    "        \"Content-Type\": \"application/json\"\n",
    "    }\n",
    "    \n",
    "    # Standard style suffix used in the GachaService\n",
    "    master_suffix = (\n",
    "        \", official 2D Pokémon-style illustration, Ken Sugimori watercolor art style, \"\n",
    "        \"cute chibi anime creature design, thick bold black ink outline, heavy contour inking, \"\n",
    "        \"clean crisp character silhouette, full body front-facing view, \"\n",
    "        \"flat cel-shaded coloring with simple soft highlights, \"\n",
    "        \"pure white background, isolated character only, no background elements, no scenery \"\n",
    "        \"--no realistic rendering, no 3D, no photorealism, no thin lines, no missing outline, \"\n",
    "        \"no shadow on ground, no texture overlays, no noise\"\n",
    "    )\n",
    "    \n",
    "    final_prompt = f\"{prompt}{master_suffix}\" if use_master_suffix else prompt\n",
    "    \n",
    "    payload = {\n",
    "        \"model\": \"google/imagen-4\",\n",
    "        \"input\": {\n",
    "            \"prompt\": final_prompt,\n",
    "            \"aspect_ratio\": \"1:1\"\n",
    "        }\n",
    "    }\n",
    "    \n",
    "    print(f\"Final Prompt: {final_prompt}\\n\")\n",
    "    print(\"Calling Google Imagen 4 model (1:1)...\")\n",
    "    \n",
    "    with httpx.Client(timeout=120.0) as client:\n",
    "        response = client.post(url, headers=headers, json=payload)\n",
    "        if response.status_code != 200:\n",
    "            raise Exception(f\"Cloudflare Imagen-4 API error ({response.status_code}): {response.text}\")\n",
    "            \n",
    "        result = response.json()\n",
    "        image_url = result.get(\"result\", {}).get(\"image\", \"\")\n",
    "        if not image_url:\n",
    "            raise Exception(f\"Failed to find image URL in response: {result}\")\n",
    "            \n",
    "        print(f\"Imagen 4 returned image URL: {image_url} — downloading...\")\n",
    "        img_response = client.get(image_url, timeout=60.0)\n",
    "        if img_response.status_code != 200:\n",
    "            raise Exception(f"Failed to download image ({img_response.status_code}): {img_response.text}")\n",
    "            \n",
    "        return img_response.content"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Set your prompt here\n",
    "test_prompt = \"a cute electric fire dragon, smiling, playful\"\n",
    "output_filename = \"test_imagen4_output.png\"\n",
    "use_pokemon_suffix = True  # Set to True to use the Sugimori/Pokemon style suffix\n",
    "\n",
    "try:\n",
    "    img_bytes = generate_image_imagen4(test_prompt, use_master_suffix=use_pokemon_suffix)\n",
    "    \n",
    "    # Load image and display in the notebook\n",
    "    image = Image.open(io.BytesIO(img_bytes))\n",
    "    display(image)\n",
    "    \n",
    "    # Save the output file\n",
    "    image.save(output_filename)\n",
    "    print(f\"✅ Image successfully saved to: {output_filename}\")\n",
    "except Exception as e:\n",
    "    print(f\"❌ Error: {e}\")"
   ]
  }
 ],
